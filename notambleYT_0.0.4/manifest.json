{
  "manifest_version": 3,
  "name": "YouTube",
  "version": "1.0",
  "description": "Uma extensão para o YouTube",
  "permissions": [
    "activeTab"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["https://www.youtube.com/*"],
      "js": ["content.js"]
    }
  ]
}

